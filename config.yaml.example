http:
  port: 8080
  shutdown: "30s"
  driver: "sqlite|turso|pgsql"
logging:
  level: "debug"
  type:  "json"
sqlite:
  db_name: "blockqueue"
  busy_timeout: 5000
  cache_size: -4000   # 4MB page cache (negative = KB)
  mmap_size: 0        
turso:
  url: "libsql://tursodatabase-username.turso.io"
pgsql:
  host: "localhost"
  username: "postgres"
  password: ""
  name: "blockqueue"
  port: 5432
  timezone: "UTC"
  max_open_conns: 10
  max_idle_conns: 10
write_buffer:
  batch_size: 100          # Messages per batch
  flush_interval: "100ms"  # Max time before flush
  buffer_size: 10000       # Channel buffer size
metric:
  enable: false